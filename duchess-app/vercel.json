{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/paperwork-delivery-note-pdf.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/sync", "schedule": "*/10 * * * *" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
